{
  "entities": {
    "Attendee": {
      "title": "Attendee",
      "description": "An individual in the attendance list",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["present", "absent", "excused", "pending", "early", "late", "unpaid", "present_early", "present_late"]
        },
        "playerId": { "type": "string" },
        "rosterRole": { "type": "string", "enum": ["starter", "reserve", null] },
        "checkInTime": { "type": "string" },
        "checkedInAt": { "type": "string" },
        "punctualityStatus": { "type": "string", "enum": ["early", "late", null] },
        "punctualitySource": { "type": "string", "enum": ["auto", "manual", null] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status"]
    },
    "Session": {
      "title": "Session",
      "description": "A saved attendance session",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "userId": { "type": "string" },
        "attendees": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isCancelled": { "type": "boolean" },
        "expenses": { "type": "array" },
        "totalExpenses": { "type": "number" },
        "expectedRevenue": { "type": "number" },
        "netForBox": { "type": "number" },
        "sessionCost": { "type": "number" }
      },
      "required": ["title", "attendees"]
    },
    "Player": {
      "title": "Player",
      "description": "A team member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "weeklyDebt": { "type": "number" },
        "monthlyDebt": { "type": "number" },
        "debtHistory": { "type": "array" },
        "isDeleted": { "type": "boolean" },
        "isExcused": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "monthlySubscriptions": { "type": "object" },
        "penaltyPreview": { "type": "object" }
      },
      "required": ["name"]
    },
    "TeamDebt": {
      "title": "TeamDebt",
      "description": "Team level debt",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "creditor": { "type": "string" },
        "date": { "type": "string" },
        "note": { "type": "string" },
        "isPaid": { "type": "boolean" },
        "paidDate": { "type": "string" },
        "isDeleted": { "type": "boolean" },
        "deletedDate": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "creditor", "date"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" },
        "isPaid": { "type": "boolean" },
        "paidDate": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "monthKey": { "type": "string" },
        "source": { "type": "string" },
        "note": { "type": "string" },
        "playerId": { "type": "string" },
        "sessionId": { "type": "string" },
        "expenseItemId": { "type": "string" }
      },
      "required": ["amount", "type", "date"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "Global user settings",
      "type": "object",
      "properties": {
        "nextSerial": { "type": "number" },
        "receiptTemplate": { "type": "string" },
        "financialSettings": { "type": "object" },
        "processedSubscriptionMonths": { "type": "object" },
        "subscriptionReviewReminderAt": { "type": "string" },
        "manuallyExcludedSubscriptionPlayers": { "type": "object" },
        "exportSettings": { "type": "object" },
        "competitionSettings": { "type": "object" },
        "archivedCompetitions": { "type": "array" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserSettings",
      "description": "Settings for a specific user"
    },
    "users/{userId}/attendees/{attendeeId}": {
      "schema": "Attendee",
      "description": "Attendees for a specific user"
    },
    "users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Saved attendance sessions for a specific user"
    },
    "users/{userId}/players/{playerId}": {
      "schema": "Player",
      "description": "Players for a specific user"
    },
    "users/{userId}/teamDebts/{teamDebtId}": {
      "schema": "TeamDebt",
      "description": "Team debts for a specific user"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transactions for a specific user"
    }
  }
}
